{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "podcast-poster",
  "server": {
    "dir": "dist/server",
    "entry": "index.js"
  },
  "menu": {
    "items": [
      {
        "label": "Post most recent episode",
        "description": "Fetches the latest episode from all configured RSS feeds and creates new posts.",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/on-app-install"
  },
  "scheduler": {
    "tasks": {
      "checkRss": {
        "endpoint": "/internal/cron/check-rss",
        "cron": "*/15 * * * *"
      }
    }
  },
  "scripts": {
    "dev": "node --experimental-strip-types ./tools/build.ts --watch",
    "build": "node --experimental-strip-types ./tools/build.ts --minify"
  },
  "permissions": {
    "http": {
      "enable": true,
      "domains": [
        "rss.art19.com",
        "omny.fm",
        "traffic.omny.fm"
      ]
    }
  },
  "dev": {
    "subreddit": "podcast_poster_dev"
  },
  "settings": {
    "subreddit": {
      "rssFeedsList": {
        "type": "paragraph",
        "label": "RSS Feeds List",
        "helpText": "Enter one feed per line. Format: https://rss.url.com | Optional Podcast Name | Optional Reason for URL Access",
        "defaultValue": "https://rss.art19.com/get-played | Get Played | Fetching RSS feed to check for new episodes"
      }
    }
  }
}