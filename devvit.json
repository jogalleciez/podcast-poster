{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "podcast-poster",
  "server": {
    "dir": "dist/server",
    "entry": "index.js"
  },
  "menu": {
    "items": [
      {
        "label": "Post most recent episode",
        "description": "Fetches the latest episode from configured RSS feed and creates new posts.",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "Edit post body",
        "description": "Edit the text body of this episode post.",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/edit-post-body"
      }
    ]
  },
  "forms": {
    "editPostBodyForm": "/internal/form/edit-post-body-submit",
    "selectFeedForm": "/internal/form/select-feed-submit"
  },
  "triggers": {
    "onAppInstall": "/internal/on-app-install"
  },
  "scheduler": {
    "tasks": {
      "checkRss": {
        "endpoint": "/internal/cron/check-rss",
        "cron": "*/15 * * * *"
      }
    }
  },
  "scripts": {
    "dev": "node --experimental-strip-types ./tools/build.ts --watch",
    "build": "node --experimental-strip-types ./tools/build.ts --minify"
  },
  "permissions": {
    "reddit": true,
    "http": {
      "enable": true,
      "domains": [
        "rss.art19.com",
        "traffic.omny.fm",
        "feeds.buzzsprout.com",
        "feeds.redcircle.com",
        "feeds.transistor.fm",
        "feeds.captivate.fm",
        "feed.podbean.com",
        "media.rss.com",
        "feeds.acast.com",
        "feed.ausha.co",
        "rss.hubhopper.com",
        "feeds.simplecast.com",
        "api.simplecast.com",
        "mp3s.simplecast.com",
        "cdn.simplecast.com",
        "image.simplecastcdn.com",
        "injector.simplecastaudio.com",
        "api.spreaker.com",
        "cdn.atp.fm",
        "podcasts.files.bbci.co.uk"
      ]
    }
  },
  "dev": {
    "subreddit": "podcast_poster_dev"
  },
  "settings": {
    "subreddit": {
      "appEnabled": {
        "type": "boolean",
        "label": "App Enabled",
        "helpText": "Turn this on to enable automatic checking and posting of new podcast episodes.",
        "defaultValue": true
      },
      "feedUrls": {
        "type": "paragraph",
        "label": "RSS Feed URLs",
        "helpText": "One feed per line, format: URL | Podcast Name | Link URL. Only the URL is required. See the README for examples and details.",
        "defaultValue": ""
      },
      "postFlairId": {
        "type": "string",
        "label": "Post Flair Template ID",
        "helpText": "Optional. The flair template ID to apply to each episode post. Find this in your subreddit's Flair settings (it looks like a UUID).",
        "defaultValue": ""
      },
      "postFlairText": {
        "type": "string",
        "label": "Post Flair Text Override",
        "helpText": "Optional. Custom flair text to display. Only used when a Flair Template ID is set above.",
        "defaultValue": ""
      },
      "pollingFrequency": {
        "type": "select",
        "label": "Polling Frequency",
        "options": [
          {
            "label": "Hourly",
            "value": "hourly"
          },
          {
            "label": "Daily",
            "value": "daily"
          },
          {
            "label": "Weekly",
            "value": "weekly"
          }
        ],
        "defaultValue": "hourly"
      },
      "weeklyPollingDay": {
        "type": "select",
        "label": "Weekly Polling Day",
        "options": [
          {
            "label": "Sunday",
            "value": "0"
          },
          {
            "label": "Monday",
            "value": "1"
          },
          {
            "label": "Tuesday",
            "value": "2"
          },
          {
            "label": "Wednesday",
            "value": "3"
          },
          {
            "label": "Thursday",
            "value": "4"
          },
          {
            "label": "Friday",
            "value": "5"
          },
          {
            "label": "Saturday",
            "value": "6"
          }
        ],
        "defaultValue": "0"
      }
    }
  }
}