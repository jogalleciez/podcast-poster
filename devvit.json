{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "podcast-poster",
  "server": {
    "dir": "dist/server",
    "entry": "index.js"
  },
  "menu": {
    "items": [
      {
        "label": "Post most recent episode",
        "description": "Fetches the latest episode from configured RSS feed and creates new posts.",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/on-app-install"
  },
  "scheduler": {
    "tasks": {
      "checkRss": {
        "endpoint": "/internal/cron/check-rss",
        "cron": "*/15 * * * *"
      }
    }
  },
  "scripts": {
    "dev": "node --experimental-strip-types ./tools/build.ts --watch",
    "build": "node --experimental-strip-types ./tools/build.ts --minify"
  },
  "permissions": {
    "http": {
      "enable": true,
      "domains": [
        "rss.art19.com",
        "omny.fm",
        "traffic.omny.fm",
        "anchor.fm",
        "castos.com",
        "feeds.buzzsprout.com",
        "feeds.redcircle.com",
        "feeds.transistor.fm",
        "feeds.captivate.fm",
        "libsyn.com",
        "feed.podbean.com",
        "media.rss.com",
        "feeds.acast.com",
        "feed.ausha.co",
        "squarespace.com",
        "rss.hubhopper.com",
        "audioboom.com",
        "awesound.com",
        "backtracks.fm",
        "blogtalkradio.com",
        "blubrry.com",
        "buzzsprout.com",
        "fireside.fm",
        "megaphone.fm",
        "omnystudio.com",
        "pinecast.com",
        "pippa.io",
        "podbean.com",
        "podcastblastoff.com",
        "podcasts.com",
        "podcastwebsites.com",
        "podiant.co",
        "podigee.com",
        "podomatic.com",
        "podpoint.com",
        "shoutengine.com",
        "simplecast.com",
        "soundcloud.com",
        "spreaker.com",
        "talkshoe.com",
        "transistor.fm",
        "trycast.com",
        "whooshkaa.com",
        "zencast.fm"
      ]
    }
  },
  "dev": {
    "subreddit": "podcast_poster_dev"
  },
  "settings": {
    "subreddit": {
      "appEnabled": {
        "type": "boolean",
        "label": "App Enabled",
        "helpText": "Turn this on to enable automatic checking and posting of new podcast episodes.",
        "defaultValue": true
      },
      "feedUrl": {
        "type": "string",
        "label": "RSS Feed URL",
        "helpText": "Enter the URL of the podcast RSS feed. e.g. https://rss.art19.com/get-played",
        "defaultValue": ""
      },
      "feedName": {
        "type": "string",
        "label": "Optional Podcast Name",
        "helpText": "Overrides the default podcast name harvested from the RSS feed if provided.",
        "defaultValue": ""
      },
      "postLinkUrl": {
        "type": "string",
        "label": "Post Link URL",
        "helpText": "Enter the URL to be used for the Reddit link post. If left blank, it will fall back to the episode audio URL.",
        "defaultValue": ""
      },
      "pollingFrequency": {
        "type": "select",
        "label": "Polling Frequency",
        "options": [
          {
            "label": "Hourly",
            "value": "hourly"
          },
          {
            "label": "Daily",
            "value": "daily"
          },
          {
            "label": "Weekly",
            "value": "weekly"
          }
        ],
        "defaultValue": "hourly"
      },
      "weeklyPollingDay": {
        "type": "select",
        "label": "Weekly Polling Day",
        "options": [
          { "label": "Sunday", "value": "0" },
          { "label": "Monday", "value": "1" },
          { "label": "Tuesday", "value": "2" },
          { "label": "Wednesday", "value": "3" },
          { "label": "Thursday", "value": "4" },
          { "label": "Friday", "value": "5" },
          { "label": "Saturday", "value": "6" }
        ],
        "defaultValue": "0"
      }
    }
  }
}