{
  "private": true,
  "name": "podcast-poster",
  "version": "0.0.0",
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "build": "node --experimental-strip-types ./tools/build.ts --minify",
    "deploy": "npm run build && devvit upload",
    "dev": "devvit playtest",
    "login": "devvit login",
    "launch": "npm run build && npm run deploy && devvit publish",
    "type-check": "tsc --build"
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "dependencies": {
    "@devvit/web": "0.12.20",
    "devvit": "0.12.20",
    "fast-xml-parser": "^5.4.1",
    "node-html-markdown": "^2.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "22.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "0.27.2",
    "typescript": "5.9.3"
  }
}
